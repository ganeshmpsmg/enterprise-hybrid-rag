# DO NOT commit real secrets to git. Use this as a template.
# Create with: kubectl create secret generic rag-secrets --from-env-file=.env -n rag-system
apiVersion: v1
kind: Secret
metadata:
  name: rag-secrets
  namespace: rag-system
type: Opaque
stringData:
  OPENAI_API_KEY: "sk-your-openai-key"
  POSTGRES_PASSWORD: "your-db-password"
  POSTGRES_USER: "raguser"
  SECRET_KEY: "your-secret-key"
  QDRANT_API_KEY: ""
